# Client-side configuration
# Set to 'null' for local development to remove /webapp prefix from routes
NEXT_PUBLIC_BASE_PATH=null
COOKIE_DOMAIN=localhost

# Public app URL (used for absolute URLs, redirects, manifests)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Content Security Policy - Frame Ancestors Configuration
# Controls which domains can embed the webapp in iframes
# Options:
# - Leave empty/unset: Use default allowed domains (Farcaster, self)
# - Specific domains: "https://merchant1.com https://merchant2.com"
# - Wildcard patterns: "https://*.wordpress.com https://*.shopify.com"
# - '*' to allow all domains (use with caution in production)
# ALLOWED_FRAME_ANCESTORS=https://*.wordpress.com https://*.shopify.com

# Server-side only (runtime)
# Chain ID for your EVM network (e.g., 1 for Ethereum, 137 for Polygon, 43113 for Avalanche Fuji, 84532 for Base Sepolia, 8453 for Base Mainnet)
CHAIN_ID=8453
# RPC URL for your chosen network
# NOTE: test_on_prod uses a keyed Ankr endpoint (secret); use a public Base RPC for local dev
RPC_URL=https://mainnet.base.org
# Block explorer base URL for your chosen network (used to build transaction/address links)
EXPLORER_BASE_URL=https://base.blockscout.com

# Token Configuration (NEW - Centralized)
# JSON array of supported tokens with enhanced metadata
# When SUPPORTED_TOKENS is provided, individual token env vars are optional (legacy fallback)
SUPPORTED_TOKENS=[{"symbol":"USDC","address":"0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913","name":"USD Coin","decimals":6,"isDefault":true,"icon":"/tokens/usdc.svg","color":"#2775CA","enabled":true,"chainId":8453},{"symbol":"USDT","address":"0xfde4C96c8593536E31F229EA8f37b2ADa2699bb2","name":"Tether USD","decimals":6,"isDefault":false,"icon":"/tokens/usdt.svg","color":"#26A17B","enabled":true,"chainId":8453},{"symbol":"DAI","address":"0x50c5725949A6F0c72E6C4a641F24049A917DB0Cb","name":"Dai Stablecoin","decimals":18,"isDefault":false,"icon":"/tokens/dai.svg","color":"#F4B731","enabled":true,"chainId":8453},{"symbol":"GBPF","address":"0x836f4b0e5774eDb800F4e0741E825Ee6F8cD6bf6","name":"Freehold GBP","decimals":18,"isDefault":false,"icon":"/tokens/gbpf.svg","color":"#1E3A5F","enabled":true,"chainId":8453}]

# Legacy Token Configuration (Optional - Fallback when SUPPORTED_TOKENS not provided)
# USDC contract address on your chosen network
USDC_CONTRACT_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# USDT contract address on your chosen network
USDT_CONTRACT_ADDRESS=0xfde4C96c8593536E31F229EA8f37b2ADa2699bb2
# Default token symbol to use (e.g., USDC, USDT, DAI)
DEFAULT_TOKEN_SYMBOL=USDC
MOONPAY_API_KEY=your_moonpay_api_key_here
# Coinbase Onramp (CDP) - used as the default fiat on-ramp for non-NGN users
# Project ID from https://portal.cdp.coinbase.com (UUID, exposed to frontend)
COINBASE_PROJECT_ID=37c83e48-6b76-4104-a5b5-469b83500c43
# CDP API key ID (UUID from the downloaded JSON `id` field) - server-side only
COINBASE_API_KEY_ID=your-api-key-uuid
# CDP API key secret (base64-encoded Ed25519 key from the downloaded JSON `privateKey` field) - server-side only
COINBASE_API_KEY_SECRET=your_base64_ed25519_secret_here
# Exchange Rate API URL for currency conversion (optional, defaults to Coinbase)
# NEXT_PUBLIC_EXCHANGE_RATE_API_URL=https://api.coinbase.com/v2/exchange-rates

# Backend services (shared dev instances)
USER_SERVICE_URL=https://devuserservice.conduit-ucpi.com
CHAIN_SERVICE_URL=https://devchainservice.conduit-ucpi.com
CONTRACT_SERVICE_URL=https://devcontractservice.conduit-ucpi.com
# Projects (fan-out / completion escrow) services
# No public dev URL provided yet - update if you have dev fan-out endpoints
FANOUT_SERVICE_URL=http://localhost:8083
FANOUT_CHAIN_SERVICE_URL=http://localhost:8979
X_API_KEY=your_chain_service_api_key_here

# Gas configuration
MIN_GAS_WEI=5
# Max gas price (gwei) before transactions are rejected
MAX_GAS_PRICE_GWEI=0.03
# Max total gas cost (gwei) before transactions are rejected
MAX_GAS_COST_GWEI=14800
# Multiplier applied to the estimated gas price
GAS_PRICE_BUFFER=1.2
# Per-operation gas limits (foundry gas estimates)
USDC_GRANT_FOUNDRY_GAS=65000
DEPOSIT_FUNDS_FOUNDRY_GAS=86500
RESOLUTION_VOTE_FOUNDRY_GAS=80000
RAISE_DISPUTE_FOUNDRY_GAS=150000
CLAIM_FUNDS_FOUNDRY_GAS=40800

SERVICE_LINK=http://localhost:3000
PRODUCT_NAME=Instant Escrow

# WalletConnect project ID (get from https://cloud.walletconnect.com)
WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Farcaster / Neynar
NEYNAR_API_KEY=your_neynar_api_key_here
NEYNAR_API_URL=https://api.neynar.com/v2/farcaster

# Session / Database
# Secret used to sign session cookies
SESSION_SECRET=your_session_secret_here
# Shopify merchant settings storage (OPTIONAL).
# Leave blank to use an in-memory store (data lost on restart).
MONGODB_URI=
# MONGODB_DB=shopify-app

# Shopify integration
SHOPIFY_CLIENT_ID=your_shopify_client_id_here
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret_here
SHOPIFY_NAME=buyer-protected-usdc-checkout
SHOPIFY_SCOPES=write_orders,write_draft_orders,write_products,read_customers

# Advertising Tracking
# Reddit Pixel ID (get from Reddit Ads Manager: https://ads.reddit.com)
NEXT_PUBLIC_REDDIT_PIXEL_ID=your_reddit_pixel_id_here
